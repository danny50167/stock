<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="css/global.css" />
    <link rel="stylesheet" href="css/signup.css" />
    <title>Stock</title>
  </head>
  <body>
    <div id="div_form">
      <fieldset>
        <input
          autocomplete="off"
          type="text"
          class="UI"
          placeholder="Name"
          id="input_name"
        />
      </fieldset>
      <fieldset>
        <input
          autocomplete="off"
          type="text"
          placeholder="ID"
          id="input_id"
        />
        <button id="btn_idCheck">Check</button>
      </fieldset>
      <fieldset>
        <input
          autocomplete="off"
          type="password"
          class="UI"
          placeholder="Password"
          id="input_pw"
        />
      </fieldset>
      <fieldset>
        <input
          autocomplete="off"
          type="password"
          class="UI"
          placeholder="Password Check"
          id="input_pwCheck"
        />
      </fieldset>
      <fieldset>
        <button hidden class="UI" id="btn_done">Start Stocking!</button>
      </fieldset>
    </div>

    <script src="client/signup.js"></script>
  </body>
</html>
